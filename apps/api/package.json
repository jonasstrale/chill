{
  "name": "@economy/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/**/*.integration.test.ts"
  },
  "dependencies": {
    "@economy/db": "workspace:*",
    "@economy/domain": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@fastify/sensible": "^6.0.3",
    "fastify": "^5.6.0",
    "jose": "^6.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "eslint": "^10.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
